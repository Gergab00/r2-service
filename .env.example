# .env.example — este SÍ va al repo
# Copia este archivo como .env y rellena los valores reales

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Servidor
PORT=3000
NODE_ENV=development

# Autenticación del microservicio
API_KEY=

# Remote Fetch (descarga de imágenes desde hosts remotos hacia R2)
REMOTE_FETCH_ALLOWED_HOSTS=host1.example.com,host2.example.com
REMOTE_FETCH_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,image/svg+xml
REMOTE_FETCH_MAX_BYTES=5242880
REMOTE_FETCH_TIMEOUT_MS=10000
REMOTE_FETCH_MAX_REDIRECTS=3
