{
  "name": "r2-service",
  "version": "1.0.0",
  "description": "Microservicio para gestión de archivos en Cloudflare R2",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/lib-storage": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "^1.2.3",
    "@scalar/hono-api-reference": "^0.10.4",
    "hono": "^4.12.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@scalar/types": "^0.7.4",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
