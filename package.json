{
  "name": "r2-service",
  "version": "1.0.0",
  "description": "Microservicio para gestión de archivos en Cloudflare R2",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prepare": "husky",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "generate:api-key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "commitlint": "commitlint --edit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/lib-storage": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "^1.2.3",
    "@scalar/hono-api-reference": "^0.10.4",
    "dotenv": "^17.3.1",
    "hono": "^4.12.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@scalar/types": "^0.7.4",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "^10.3.5",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "semantic-release": "^23.1.1",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
